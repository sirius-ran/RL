# Public configuration template for bcWarmSoftFilterValSelect.
# Replace the placeholder paths with authorized local data paths.

RUN_TAG=bcWarmSoftFilterValSelect
SEED=42
TRAIN_DATA_PATH=<authorized-training-data.csv>
VAL_DATA_PATH=<authorized-development-data.csv>

MAX_EPISODES=200
WARMUP_STEPS=5000
ACTION_MODE=absolute

USE_BC_REG=1
BC_REG_TARGET=demo
BC_REG_MODE=action
BC_REG_Q_FILTER=1
BC_Q_FILTER_MARGIN=0.0
BC_REG_ADV_WEIGHT=0
BC_REG_LAMBDA_START=1.0
BC_REG_LAMBDA_END=0.05
BC_REG_DECAY_EPISODES=120
BC_REG_WARM_EPISODES=0
BC_DEMO_BATCH_SIZE=256

BC_DEMO_FILTER_MODE=soft
BC_QUALITY_MAE_THRESHOLD=50.0
BC_QUALITY_WINDOW=3
BC_FILTER_U_MIN=5.0
BC_FILTER_U_MAX=95.0
BC_FILTER_MAX_DELTA_U=12.0
BC_FILTER_MAX_LOAD_DELTA=25.0
BC_FILTER_IMPROVE_HORIZON=5
BC_FILTER_IMPROVE_TOL=0.0
BC_FILTER_IMPROVE_MIN_ERROR=2.0
BC_FILTER_CHECK_DIRECTION=1
BC_SOFT_WEIGHT_MIN=0.20
BC_SOFT_WEIGHT_SATURATION=0.70
BC_SOFT_WEIGHT_ACTION_JUMP=0.60
BC_SOFT_WEIGHT_LOAD_JUMP=0.80
BC_SOFT_WEIGHT_WRONG_DIRECTION=0.35
BC_SOFT_WEIGHT_NO_IMPROVEMENT=0.70
BC_SOFT_SNAP_DEADZONE=0

USE_VAL_SELECTION=1
VAL_EVERY_EPISODES=10
VAL_MAX_STEPS=500
VAL_NUM_STARTS=3
VAL_SELECTION_OBJECTIVE=mae
